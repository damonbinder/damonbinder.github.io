---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getRiver } from '../../lib/river.ts';

// Only native posts get their own page. Link posts (external set) are
// surfaced in the river but click straight through to their source.
// Prev/next step through native posts only, so navigation always stays
// on-site rather than handing off to an external link post.
export async function getStaticPaths() {
  const [posts, river] = await Promise.all([getCollection('writing'), getRiver()]);
  const byId = new Map(posts.map((p) => [p.id, p]));
  const nativeItems = river.filter((item) => item.native);

  const link = (item: (typeof nativeItems)[number] | undefined) =>
    item ? { title: item.title, href: `/blog/${item.id}/` } : null;

  return nativeItems.map((item, i) => ({
    params: { slug: item.id },
    props: { post: byId.get(item.id)!, prev: link(nativeItems[i + 1]), next: link(nativeItems[i - 1]) },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base title={post.data.title} description={post.data.excerpt}>
  <article>
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
    </div>
    <Content />
  </article>

  <nav class="post-nav">
    <div class="post-nav-prev">
      {prev && <a href={prev.href}>← {prev.title}</a>}
    </div>
    <div class="post-nav-all"><a href="/blog/">All posts</a></div>
    <div class="post-nav-next">
      {next && <a href={next.href}>{next.title} →</a>}
    </div>
  </nav>
</Base>

<style>
  .post-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .post-nav a { text-decoration: none; color: var(--muted); }
  .post-nav a:hover { color: var(--accent); }
  .post-nav-all { text-align: center; white-space: nowrap; }
  .post-nav-next { text-align: right; }

  @media (max-width: 600px) {
    .post-nav { grid-template-columns: 1fr; text-align: center; gap: 0.6rem; }
    .post-nav-next { text-align: center; }
  }
</style>
