---
import Base from '../../layouts/Base.astro';
import { Content } from '../../data/simulations.md';
---
<Base title="Simulations" description="Interactive physics simulations you can play with in the browser.">
  <div class="simlist">
    <Content />
  </div>
</Base>

<style>
  .simlist :global(ul) {
    list-style: none;
    padding-left: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 0.4rem 1.5rem;
  }
  .simlist :global(li) { margin: 0; }
</style>
