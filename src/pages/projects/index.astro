---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects.ts';
---
<Base title="Projects" description="Things I've built on the side.">
  <h1>Projects</h1>
  <ul class="post-list">
    {projects.map((proj) => (
      <li class="post-item">
        <div class="post-meta">
          <time>{proj.date}</time>
        </div>
        <h3>{proj.href ? <a href={proj.href}>{proj.title}</a> : proj.title}</h3>
        <p class="muted">{proj.blurb}</p>
      </li>
    ))}
  </ul>
</Base>
