---
import Base from '../../layouts/Base.astro';
import { getRiver } from '../../lib/river.ts';

export async function getStaticPaths() {
  const posts = await getRiver();
  const tags = new Set<string>();
  for (const p of posts) for (const t of p.tags) tags.add(t);
  return [...tags].map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<Base title={`#${tag}`} description={`Posts tagged ${tag}.`}>
  <h1>{tag}</h1>
  <p class="muted"><a href="/blog/">← All posts</a></p>
  <ul class="post-list">
    {posts.map((p) => (
      <li class="post-item">
        <div class="post-meta">
          <time datetime={p.date.toISOString()}>{fmt(p.date)}</time>
          {p.source && <span class="source-badge">{p.source}</span>}
        </div>
        <h3>
          {p.external ? (
            <a href={p.external}>{p.title} <span class="external-arrow">↗</span></a>
          ) : (
            <a href={`/blog/${p.id}/`}>{p.title}</a>
          )}
        </h3>
        {p.excerpt && <p class="muted">{p.excerpt}</p>}
      </li>
    ))}
  </ul>
</Base>
