---
import { catSlug, showingDrafts, workOf, pageOf } from '../lib/recipes.ts';

interface Props { recipe: any; showWork?: boolean }
const { recipe, showWork = false } = Astro.props;
const d = recipe.data;
const href = `/recipes/${catSlug(pageOf(d))}/${recipe.id}/`;
const em = (s: string) => s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
const snippet = d.description
  ? d.description.length > 140 ? d.description.slice(0, 140).trim() + '…' : d.description
  : null;
---
<a class="recipe-card" href={href}>
  <div class="rc-top">
    <h3 set:html={em(d.title)}></h3>
    {showingDrafts && (
      d.status === 'draft'
        ? <span class="rc-tag draft">Draft</span>
        : <span class="rc-tag live">Live</span>
    )}
  </div>
  <p class="rc-source">{showWork ? (d.source ?? workOf(d)) : (d.source ?? '')}</p>
  {snippet && <p class="rc-desc" set:html={em(snippet)}></p>}
</a>

<style>
  .recipe-card {
    display: block;
    background: var(--card);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.15s;
  }
  .recipe-card:hover { border-color: var(--accent); }
  .rc-top { display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .recipe-card h3 {
    margin: 0;
    font-size: 1.05rem;
    font-family: var(--font-sans);
    font-weight: 600;
    line-height: 1.25;
  }
  .recipe-card:hover h3 { color: var(--accent); }
  .rc-tag {
    flex: 0 0 auto;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
  }
  .rc-tag.draft { color: #8a5a00; background: #fbf0d8; border: 1px solid #e8d29a; }
  .rc-tag.live { color: #2e7d4f; background: #e7f4ec; border: 1px solid #b7dcc4; }
  .rc-source {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0.3rem 0 0;
  }
  .rc-desc { margin: 0.5rem 0 0; font-size: 0.92rem; color: var(--fg); }
</style>
